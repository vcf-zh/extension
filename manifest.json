{
  "manifest_version": 3,
  "name": "VCF 中文化",
  "version": "1.3.0",
  "description": "为 VMware Cloud Foundation 提供中文界面，自动翻译未覆盖的字符串",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/updater.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "content/translator.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "options/options.html",
    "default_title": "VCF 中文化"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "vcf-zh@vcf-zh.github.io",
      "strict_min_version": "109.0"
    }
  }
}